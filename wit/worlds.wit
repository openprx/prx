/// PRX Plugin System — World definitions.
///
/// Each world represents a plugin capability type.
/// Plugins target a specific world to declare their capability.

package prx:plugin@0.1.0;

/// Tool world — plugins that provide LLM-callable tools.
///
/// Imports: host functions the plugin can call.
/// Exports: functions the host calls to use the tool.
world tool {
    import prx:host/log;
    import prx:host/config;
    import prx:host/kv;
    import prx:host/http-outbound;
    import prx:host/memory;

    export prx:plugin/tool-exports;
}

/// Base world — minimal plugin with only logging and KV.
world base-plugin {
    import prx:host/log;
    import prx:host/config;
    import prx:host/kv;
}
