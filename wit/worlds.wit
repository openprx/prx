/// PRX Plugin System — World definitions.
///
/// Each world represents a plugin capability type.
/// Plugins target a specific world to declare their capability.

package prx:plugin@0.1.0;

/// Tool world — plugins that provide LLM-callable tools.
///
/// Imports: host functions the plugin can call.
/// Exports: functions the host calls to use the tool.
world tool {
    import prx:host/log;
    import prx:host/config;
    import prx:host/kv;
    import prx:host/http-outbound;
    import prx:host/memory;
    import prx:host/events;

    export prx:plugin/tool-exports;
}

/// Middleware world — plugins that intercept and transform messages.
///
/// Middleware plugins can modify data at various pipeline stages:
/// inbound, outbound, llm_request, llm_response.
world middleware {
    import prx:host/log;
    import prx:host/config;
    import prx:host/kv;
    import prx:host/events;

    export prx:plugin/middleware-exports;
}

/// Hook world — plugins that observe lifecycle events.
///
/// Hook plugins receive event notifications without modifying
/// the data flow (read-only observation).
world hook {
    import prx:host/log;
    import prx:host/config;
    import prx:host/kv;
    import prx:host/events;

    export prx:plugin/hook-exports;
}

/// Cron world — plugins that run on a schedule.
///
/// Cron plugins are invoked by the scheduler based on their
/// declared cron expression in the manifest.
world cron {
    import prx:host/log;
    import prx:host/config;
    import prx:host/kv;
    import prx:host/events;

    export prx:plugin/cron-exports;
}

/// Provider world — plugins that serve as LLM providers.
///
/// Provider plugins receive chat completion requests from the host
/// and return responses, allowing WASM plugins to act as custom LLM backends.
world provider {
    import prx:host/log;
    import prx:host/config;
    import prx:host/http-outbound;
    import prx:host/events;

    export prx:plugin/provider-exports;
}

/// Base world — minimal plugin with only logging and KV.
world base-plugin {
    import prx:host/log;
    import prx:host/config;
    import prx:host/kv;
}
